# App
NEXT_PUBLIC_APP_NAME=SpecPilot
NODE_ENV=development

# Database (Docker local)
DATABASE_URL=postgresql://specpilot:specpilot@localhost:5432/specpilot?schema=public

# OpenAI
# Required for plan generation routes. Leave empty only if you do not call generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# MVP mock user
MOCK_USER_EMAIL=demo@specpilot.app
